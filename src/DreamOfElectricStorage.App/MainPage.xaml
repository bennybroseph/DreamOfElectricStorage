<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="DreamOfElectricStorage.App.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:DreamOfElectricStorage.App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <InfoBar
            x:Name="ElevationBar"
            Grid.Row="0"
            IsOpen="False"
            IsClosable="False"
            Severity="Warning"
            Title="Administrator access required"
            Message="Indexing every drive reads the NTFS master file table, which needs an elevated process.">
            <InfoBar.ActionButton>
                <Button Content="Restart as administrator" Click="OnRestartElevatedClick" />
            </InfoBar.ActionButton>
        </InfoBar>

        <!-- MaxHeight contains a phantom vertical expansion (AutoSuggestBox-related) — root cause TBD. -->
        <Grid Grid.Row="1" Padding="12,8" ColumnSpacing="12" MaxHeight="56">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <Button x:Name="UpButton" Content="&#x2191; Up" IsEnabled="False" Click="OnUpClick" />
                <Button x:Name="HomeButton" Content="&#x2302;" ToolTipService.ToolTip="Zoom to fit (Home)" Click="OnHomeClick" />
                <DropDownButton x:Name="PinsButton" Content="&#x2605;" ToolTipService.ToolTip="Pinned places">
                    <DropDownButton.Flyout>
                        <MenuFlyout x:Name="PinsFlyout" Opening="OnPinsFlyoutOpening" />
                    </DropDownButton.Flyout>
                </DropDownButton>
            </StackPanel>
            <AutoSuggestBox
                x:Name="SearchBox"
                Grid.Column="1"
                VerticalAlignment="Center"
                PlaceholderText="Search all drives…"
                QueryIcon="Find"
                IsEnabled="False"
                TextChanged="OnSearchTextChanged"
                SuggestionChosen="OnSearchSuggestionChosen"
                QuerySubmitted="OnSearchQuerySubmitted">
                <AutoSuggestBox.ItemTemplate>
                    <DataTemplate x:DataType="local:SearchResult">
                        <StackPanel Padding="0,6">
                            <TextBlock Text="{x:Bind Name}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="{x:Bind Path}" Style="{StaticResource CaptionTextBlockStyle}"
                                       Opacity="0.7" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </DataTemplate>
                </AutoSuggestBox.ItemTemplate>
            </AutoSuggestBox>
            <ComboBox x:Name="ColorModeCombo" Grid.Column="2" SelectedIndex="0"
                      SelectionChanged="OnColorModeChanged" VerticalAlignment="Center">
                <ComboBoxItem Content="Color: Type" />
                <ComboBoxItem Content="Color: Age" />
                <ComboBoxItem Content="Color: None" />
            </ComboBox>
            <ItemsControl x:Name="LegendItems" Grid.Column="3" VerticalAlignment="Center">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="8" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="local:LegendEntry">
                        <StackPanel Orientation="Horizontal" Spacing="3">
                            <Ellipse Width="9" Height="9" Fill="{x:Bind Brush}" VerticalAlignment="Center" />
                            <TextBlock Text="{x:Bind Label}" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.75" />
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <BreadcrumbBar x:Name="BreadcrumbTrail" Grid.Column="4" VerticalAlignment="Center"
                           ItemClicked="OnBreadcrumbClicked" />
            <TextBlock x:Name="StatusText" Grid.Column="5" VerticalAlignment="Center"
                       Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.8" Text="" />
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <canvas:CanvasControl
                x:Name="GraphCanvas"
                Grid.Column="0"
                Draw="OnCanvasDraw"
                ClearColor="#FF14181F"
                PointerPressed="OnCanvasPointerPressed"
                PointerMoved="OnCanvasPointerMoved"
                PointerReleased="OnCanvasPointerReleased"
                PointerWheelChanged="OnCanvasWheel"
                Tapped="OnCanvasTapped"
                DoubleTapped="OnCanvasDoubleTapped"
                RightTapped="OnCanvasRightTapped" />

            <Grid x:Name="RelatedPanel" Grid.Column="1" Width="340" Visibility="Collapsed"
                  Padding="12" RowSpacing="8" Background="{ThemeResource LayerFillColorDefaultBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock x:Name="DetailName" Grid.Row="0" Style="{StaticResource BodyStrongTextBlockStyle}" TextWrapping="Wrap" />
                <Image x:Name="DetailThumb" Grid.Row="1" MaxHeight="180" Stretch="Uniform"
                       HorizontalAlignment="Left" Visibility="Collapsed" />
                <TextBlock x:Name="DetailMeta" Grid.Row="2" Style="{StaticResource CaptionTextBlockStyle}"
                           Opacity="0.75" TextWrapping="Wrap" IsTextSelectionEnabled="True" />
                <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8">
                    <Button x:Name="DetailOpen" Content="Open" Click="OnDetailOpenClick" />
                    <Button x:Name="DetailReveal" Content="Reveal in Explorer" Click="OnDetailRevealClick" />
                </StackPanel>
                <Border x:Name="DetailTextBorder" Grid.Row="4" Visibility="Collapsed" CornerRadius="6"
                        Background="{ThemeResource SubtleFillColorSecondaryBrush}" Padding="8" MaxHeight="170">
                    <ScrollViewer>
                        <TextBlock x:Name="DetailTextPreview" FontFamily="Consolas" FontSize="11.5"
                                   TextWrapping="Wrap" IsTextSelectionEnabled="True" Opacity="0.9" />
                    </ScrollViewer>
                </Border>
                <TextBlock x:Name="RelatedTitle" Grid.Row="5" Style="{StaticResource BodyStrongTextBlockStyle}" Text="Related" />
                <TextBlock x:Name="RelatedSummary" Grid.Row="6" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.75" TextWrapping="Wrap" />
                <ListView x:Name="RelatedList" Grid.Row="7" SelectionMode="None" IsItemClickEnabled="True" ItemClick="OnRelatedItemClick">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:SearchResult">
                            <StackPanel Padding="0,6">
                                <TextBlock Text="{x:Bind Name}" Style="{StaticResource BodyTextBlockStyle}" />
                                <TextBlock Text="{x:Bind Path}" Style="{StaticResource CaptionTextBlockStyle}"
                                           Opacity="0.7" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>
    </Grid>
</Page>

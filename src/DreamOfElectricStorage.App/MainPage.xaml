<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="DreamOfElectricStorage.App.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:DreamOfElectricStorage.App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Dream of Electric Storage" Style="{StaticResource TitleTextBlockStyle}" />
        <TextBlock Grid.Row="1" x:Name="StatusText" Style="{StaticResource BodyTextBlockStyle}" />
    </Grid>
</Page>

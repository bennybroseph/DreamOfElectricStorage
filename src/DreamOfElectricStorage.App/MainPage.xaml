<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="DreamOfElectricStorage.App.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:DreamOfElectricStorage.App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <InfoBar
            x:Name="ElevationBar"
            Grid.Row="0"
            IsOpen="False"
            IsClosable="False"
            Severity="Warning"
            Title="Administrator access required"
            Message="Indexing every drive reads the NTFS master file table, which needs an elevated process.">
            <InfoBar.ActionButton>
                <Button Content="Restart as administrator" Click="OnRestartElevatedClick" />
            </InfoBar.ActionButton>
        </InfoBar>

        <!-- MaxHeight contains a phantom vertical expansion (AutoSuggestBox-related) — root cause TBD.
             Column order is priority order: breadcrumb gets the star; legend is last and clips first. -->
        <Grid Grid.Row="1" Padding="12,8" ColumnSpacing="12" MaxHeight="56">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <Button x:Name="UpButton" Content="&#x2191; Up" IsEnabled="False" Click="OnUpClick" />
                <Button x:Name="HomeButton" Content="&#x2302;" ToolTipService.ToolTip="Zoom to fit (Home)" Click="OnHomeClick" />
                <DropDownButton x:Name="PinsButton" Content="&#x2605;" ToolTipService.ToolTip="Pinned places">
                    <DropDownButton.Flyout>
                        <MenuFlyout x:Name="PinsFlyout" Opening="OnPinsFlyoutOpening" />
                    </DropDownButton.Flyout>
                </DropDownButton>
                <DropDownButton x:Name="SettingsButton" Content="&#x2699;" ToolTipService.ToolTip="Settings">
                    <DropDownButton.Flyout>
                        <Flyout Placement="BottomEdgeAlignedLeft" Opened="OnSettingsFlyoutOpened">
                            <StackPanel Spacing="10" Width="230">
                                <TextBlock Text="View" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <RadioButtons x:Name="ViewChoice" SelectionChanged="OnViewChanged">
                                    <x:String>Clusters</x:String>
                                    <x:String>Cells</x:String>
                                </RadioButtons>
                                <TextBlock Text="Theme" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <RadioButtons x:Name="ThemeChoice" SelectionChanged="OnThemeChanged">
                                    <x:String>System</x:String>
                                    <x:String>Light</x:String>
                                    <x:String>Dark</x:String>
                                </RadioButtons>
                                <StackPanel x:Name="ForcesPanel" Spacing="4">
                                    <TextBlock Text="Grouping" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,0,0,2" />
                                    <TextBlock Text="Drag to reorder — the top is the root grouping and each row nests inside the one above. Uncheck to skip a level."
                                               Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.7" TextWrapping="Wrap" Margin="0,0,0,4" />
                                    <ListView x:Name="FacetList"
                                              SelectionMode="None"
                                              CanReorderItems="True"
                                              CanDragItems="True"
                                              AllowDrop="True"
                                              ReorderMode="Enabled">
                                        <ListView.ItemContainerStyle>
                                            <Style TargetType="ListViewItem">
                                                <Setter Property="MinHeight" Value="32" />
                                                <Setter Property="Padding" Value="6,2" />
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            </Style>
                                        </ListView.ItemContainerStyle>
                                        <ListView.ItemTemplate>
                                            <DataTemplate x:DataType="local:FacetRow">
                                                <Grid ColumnSpacing="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox Grid.Column="0" MinWidth="0"
                                                              IsChecked="{x:Bind Enabled}" Tag="{x:Bind}"
                                                              Checked="OnFacetToggled" Unchecked="OnFacetToggled" />
                                                    <TextBlock Grid.Column="1" Text="{x:Bind Label}" VerticalAlignment="Center" />
                                                    <FontIcon Grid.Column="2" Glyph="&#xE76F;" FontSize="12" Opacity="0.5" VerticalAlignment="Center" />
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </StackPanel>
                                <ToggleSwitch x:Name="LegendToggle" Header="Show legend" Toggled="OnLegendToggled" />
                                <ToggleSwitch x:Name="MotionToggle" Header="Reduce motion" Toggled="OnMotionToggled" />
                                <ToggleSwitch x:Name="SystemFoldersToggle" Header="Show system folders" Toggled="OnSystemFoldersToggled" />
                            </StackPanel>
                        </Flyout>
                    </DropDownButton.Flyout>
                </DropDownButton>
            </StackPanel>
            <AutoSuggestBox
                x:Name="SearchBox"
                Grid.Column="1"
                VerticalAlignment="Center"
                PlaceholderText="Search all drives…"
                QueryIcon="Find"
                IsEnabled="False"
                TextChanged="OnSearchTextChanged"
                SuggestionChosen="OnSearchSuggestionChosen"
                QuerySubmitted="OnSearchQuerySubmitted">
                <AutoSuggestBox.ItemTemplate>
                    <DataTemplate x:DataType="local:SearchResult">
                        <StackPanel Padding="0,6">
                            <TextBlock Text="{x:Bind Name}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="{x:Bind Path}" Style="{StaticResource CaptionTextBlockStyle}"
                                       Opacity="0.7" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </DataTemplate>
                </AutoSuggestBox.ItemTemplate>
            </AutoSuggestBox>
            <BreadcrumbBar x:Name="BreadcrumbTrail" Grid.Column="2" VerticalAlignment="Center"
                           ItemClicked="OnBreadcrumbClicked" />
            <ComboBox x:Name="ColorModeCombo" Grid.Column="3" SelectedIndex="0"
                      SelectionChanged="OnColorModeChanged" VerticalAlignment="Center">
                <ComboBoxItem Content="Color: Type" />
                <ComboBoxItem Content="Color: Age" />
                <ComboBoxItem Content="Color: None" />
            </ComboBox>
            <TextBlock x:Name="StatusText" Grid.Column="4" VerticalAlignment="Center"
                       Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.8" Text="" />
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <canvas:CanvasControl
                x:Name="GraphCanvas"
                Grid.Column="0"
                Draw="OnCanvasDraw"
                ClearColor="#FF14181F"
                PointerPressed="OnCanvasPointerPressed"
                PointerMoved="OnCanvasPointerMoved"
                PointerReleased="OnCanvasPointerReleased"
                PointerWheelChanged="OnCanvasWheel"
                Tapped="OnCanvasTapped"
                DoubleTapped="OnCanvasDoubleTapped" />

            <!-- Map-style legend overlay (toggleable in settings) — keeps the toolbar free. -->
            <Border Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                    Margin="16" CornerRadius="8" Padding="10,8"
                    Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                    x:Name="LegendPanel">
                <ItemsControl x:Name="LegendItems">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical" Spacing="3" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="local:LegendEntry">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Ellipse Width="9" Height="9" Fill="{x:Bind Brush}" VerticalAlignment="Center" />
                                <TextBlock Text="{x:Bind Label}" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.8" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <Grid x:Name="RelatedPanel" Grid.Column="1" Width="340" Visibility="Collapsed"
                  Padding="12" RowSpacing="8" Background="{ThemeResource LayerFillColorDefaultBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock x:Name="DetailName" Grid.Row="0" Style="{StaticResource BodyStrongTextBlockStyle}" TextWrapping="Wrap" />
                <Image x:Name="DetailThumb" Grid.Row="1" MaxHeight="180" Stretch="Uniform"
                       HorizontalAlignment="Left" Visibility="Collapsed" />
                <TextBlock x:Name="DetailMeta" Grid.Row="2" Style="{StaticResource CaptionTextBlockStyle}"
                           Opacity="0.75" TextWrapping="Wrap" IsTextSelectionEnabled="True" />
                <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8">
                    <Button x:Name="DetailOpen" Content="Open" Click="OnDetailOpenClick" />
                    <Button x:Name="DetailReveal" Content="Reveal in Explorer" Click="OnDetailRevealClick" />
                </StackPanel>
                <Border x:Name="DetailTextBorder" Grid.Row="4" Visibility="Collapsed" CornerRadius="6"
                        Background="{ThemeResource SubtleFillColorSecondaryBrush}" Padding="8" MaxHeight="170">
                    <ScrollViewer>
                        <TextBlock x:Name="DetailTextPreview" FontFamily="Consolas" FontSize="11.5"
                                   TextWrapping="Wrap" IsTextSelectionEnabled="True" Opacity="0.9" />
                    </ScrollViewer>
                </Border>
                <TextBlock x:Name="RelatedTitle" Grid.Row="5" Style="{StaticResource BodyStrongTextBlockStyle}" Text="Related" />
                <TextBlock x:Name="RelatedSummary" Grid.Row="6" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.75" TextWrapping="Wrap" />
                <ListView x:Name="RelatedList" Grid.Row="7" SelectionMode="None" IsItemClickEnabled="True" ItemClick="OnRelatedItemClick">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:SearchResult">
                            <StackPanel Padding="0,6">
                                <TextBlock Text="{x:Bind Name}" Style="{StaticResource BodyTextBlockStyle}" />
                                <TextBlock Text="{x:Bind Path}" Style="{StaticResource CaptionTextBlockStyle}"
                                           Opacity="0.7" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>
    </Grid>
</Page>
